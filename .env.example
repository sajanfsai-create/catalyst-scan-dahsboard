# =======================================================
# TekkiX CatalystScan — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =======================================================

# MySQL Database
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_DATABASE=tekkixscan
MYSQL_USER=tekkix_user
MYSQL_PASSWORD=your-secure-db-password
MYSQL_HOST=127.0.0.1

# Security (REQUIRED — server will refuse to start without these)
SESSION_SECRET=your-strong-random-session-secret-change-this
AGENT_API_KEY=your-agent-api-key-for-scanner-auth

# Admin Credentials (seeded into DB on first run)
ADMIN_USER=tekkix
ADMIN_PASS=Tekkix@2026

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=9000
