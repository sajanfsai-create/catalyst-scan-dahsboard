# CatalystScan Telemetry Server — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# MySQL Local Database (via Docker)
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_DATABASE=catalystscan
MYSQL_USER=catalyst
MYSQL_PASSWORD=your-secure-db-password
MYSQL_HOST=mysql

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=https://scan.bostontech.in,http://localhost:9000

# Security (REQUIRED — server will refuse to start without these)
SESSION_SECRET=your-strong-random-session-secret-change-this
AGENT_API_KEY=your-agent-api-key-for-scanner-auth

# Admin Credentials (seeded on first run)
ADMIN_USER=admin
ADMIN_PASS=your-secure-admin-password
# ADMIN_PASS_2=optional-second-admin-password

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=9000

# Email Notifications (SMTP) — Optional
# Leave blank to disable email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@catalystscan.local
SMTP_USE_TLS=true
